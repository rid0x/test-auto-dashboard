{
  "name": "test-auto",
  "version": "1.0.0",
  "description": "Multi-project Magento E2E & API test automation framework",
  "main": "index.js",
  "scripts": {
    "------- GETPRICE -------": "",
    "test:getprice": "cross-env PROJECT=getprice npx playwright test",
    "test:getprice:login": "cross-env PROJECT=getprice npx playwright test --grep @login",
    "test:getprice:registration": "cross-env PROJECT=getprice npx playwright test --grep @registration",
    "test:getprice:homepage": "cross-env PROJECT=getprice npx playwright test --grep @homepage",
    "test:getprice:search": "cross-env PROJECT=getprice npx playwright test --grep @search",
    "test:getprice:cart": "cross-env PROJECT=getprice npx playwright test --grep @cart",
    "test:getprice:checkout": "cross-env PROJECT=getprice npx playwright test --grep @checkout",
    "test:getprice:category": "cross-env PROJECT=getprice npx playwright test --grep @category",
    "test:getprice:product": "cross-env PROJECT=getprice npx playwright test --grep @product-page",
    "test:getprice:api": "cross-env PROJECT=getprice npx playwright test --grep @api",
    "test:getprice:e2e": "cross-env PROJECT=getprice npx playwright test --grep @e2e",
    "test:getprice:headed": "cross-env PROJECT=getprice npx playwright test --headed",
    "------- WILLSOOR -------": "",
    "test:willsoor": "cross-env PROJECT=willsoor npx playwright test",
    "test:willsoor:login": "cross-env PROJECT=willsoor npx playwright test --grep @login",
    "test:willsoor:registration": "cross-env PROJECT=willsoor npx playwright test --grep @registration",
    "test:willsoor:homepage": "cross-env PROJECT=willsoor npx playwright test --grep @homepage",
    "test:willsoor:search": "cross-env PROJECT=willsoor npx playwright test --grep @search",
    "test:willsoor:cart": "cross-env PROJECT=willsoor npx playwright test --grep @cart",
    "test:willsoor:checkout": "cross-env PROJECT=willsoor npx playwright test --grep @checkout",
    "test:willsoor:category": "cross-env PROJECT=willsoor npx playwright test --grep @category",
    "test:willsoor:product": "cross-env PROJECT=willsoor npx playwright test --grep @product-page",
    "test:willsoor:api": "cross-env PROJECT=willsoor npx playwright test --grep @api",
    "test:willsoor:e2e": "cross-env PROJECT=willsoor npx playwright test --grep @e2e",
    "test:willsoor:headed": "cross-env PROJECT=willsoor npx playwright test --headed",
    "------- ALL PROJECTS -------": "",
    "test:all": "npm run test:getprice && npm run test:willsoor",
    "test:all:login": "npm run test:getprice:login && npm run test:willsoor:login",
    "test:all:api": "npm run test:getprice:api && npm run test:willsoor:api",
    "------- REPORTS -------": "",
    "report:getprice": "npx playwright show-report reports/getprice/html",
    "report:willsoor": "npx playwright show-report reports/willsoor/html",
    "report:getprice:allure": "npx allure generate reports/getprice/allure-results -o reports/getprice/allure-report --clean && npx allure open reports/getprice/allure-report",
    "report:willsoor:allure": "npx allure generate reports/willsoor/allure-results -o reports/willsoor/allure-report --clean && npx allure open reports/willsoor/allure-report",
    "------- DASHBOARD -------": "",
    "dashboard": "npx nodemon --watch dashboard --watch src --ext ts,html,css,js --exec \"npx ts-node dashboard/server.ts\"",
    "dashboard:once": "npx ts-node dashboard/server.ts",
    "------- UTILS -------": "",
    "clean": "rimraf reports dist",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "magento",
    "e2e",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "ws": "^8.20.0"
  }
}
